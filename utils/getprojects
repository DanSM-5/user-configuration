#!/usr/bin/env bash

[[ -v debug ]] && set -x

base_dir="$PROJECTS_LOCATION"
if [ -z "$base_dir" ]; then
  if [ -n "$user_conf_path" ]; then
    # For personal use only. If you are interested in this script
    # you may remove this part and reduce evetything to:
    # base_dir="${PROJECTS_LOCATION:-$HOME}"
    base_dir="$user_conf_path/prj"
  else
    base_dir="$HOME"
  fi
fi

# all_directories=()

help () {
  while IFS= read -r line; do
		printf "  %s\n" "$line"
	done <<-EOF

  Get projects script

	Usage:
    ${0##*/}
    ${0##*/} [-h|--help]
    ${0##*/} [-l|--locations] [-d|--directories]
    ${0##*/} [-f|--file-locations] [/path/to/file]
    ${0##*/} [-b|--file-directories] [/path/to/file]
    ${0##*/} [-i|--include] [/path/to/directory]
    ${0##*/} [-p|--path] [/path/to/directory]
    ${0##*/} [-s|--source] [/path/to/directory]
    ${0##*/} [-u|--unique]

	Options:
    -h | --help                   Print this message
    -l | --locations              Print the content from "locations" file
    -d | --directories            Print the content from "directories" file
    -f | --file-locations         Get "locations" from the specific file provided
    -b | --file-directories       Get "directories" from the specific file provided
    -i | --include                Return "location" in the list
    -p | --path                   Get "directories" from specific path
    -s | --source                 Use source path as base directory to search for "locations" and "directories" files
    -u | --unique                 Get a list of unique items

  Arguments:
    help                          Print this message

  Environment variables:
    PROJECTS_LOCATION             Path to use to search for "locations" and "directories" file

EOF
}

# Expands variables/tilde in a raw line (via eval, a builtin) and trims
# leading/trailing whitespace using pure parameter expansion. This avoids
# forking external processes (printf/sed) per line, which is the single
# biggest cost on gitbash: each external process spawn there costs roughly
# 25-65ms (measured), so doing this per-line across a handful of external
# commands adds up to the majority of this script's runtime.
expand_and_trim () {
  local -n __out="$1"
  eval "__out=\"$2\"" 2>/dev/null || { __out=""; return 1; }
  __out="${__out#"${__out%%[![:space:]]*}"}"
  __out="${__out%"${__out##*[![:space:]]}"}"
}

# Reads a "locations"/"directories"-style file into an array of expanded,
# trimmed, non-empty, non-comment paths. Shared by get_locations and
# get_directories so both benefit from the same fork-free line processing.
read_path_list () {
  local -n __result="$1"
  local file="$2"
  local raw entry
  while IFS="" read -r raw || [ -n "$raw" ]; do
    [[ -z "$raw" || "$raw" =~ ^# ]] && continue
    expand_and_trim entry "$raw" || continue
    [ -n "$entry" ] && __result+=("$entry")
  done < "$file"
}

# Normalizes a Windows drive-letter path (C:/... or C:\...) to MSYS/POSIX
# style (/c/...); anything else passes through unchanged. On gitbash,
# `realpath` canonicalizes segments but preserves whichever notation its
# input had -- it does not unify styles. $HOME and $WIN_HOME are meant to be
# interchangeable (some entries intentionally use one or the other for
# cross-shell compatibility), but a subprocess spawned by a native Windows
# program (e.g. fzf reloading this script) can see one of them in a
# different notation than the interactive shell does, even though both
# still point at the same directory. Without normalizing, that produces the
# same directory twice under two different-looking strings, which `sort -u`
# cannot catch since the text genuinely differs.
to_posix_path () {
  local -n __out="$1"
  local p="$2"
  if [[ "$p" =~ ^([A-Za-z]):[/\\](.*)$ ]]; then
    __out="/${BASH_REMATCH[1],,}/${BASH_REMATCH[2]//\\//}"
  else
    __out="$p"
  fi
}

get_locations () {
  [ -z "$1" ] && [ "$2" = true ] && return
  local locations_file="${1:-"$base_dir/locations"}"
  [ -f "$locations_file" ] || return

  local paths=()
  read_path_list paths "$locations_file"
  [ "${#paths[@]}" -eq 0 ] && return

  # Resolve every path in a single realpath call instead of once per line.
  local dir_path norm
  while IFS="" read -r dir_path; do
    if [ -d "$dir_path" ]; then
      to_posix_path norm "${dir_path%/}"
      printf "%s\n" "$norm"
    fi
  done < <(realpath -- "${paths[@]}" 2>/dev/null)
}

# Lists immediate subdirectories (including symlinks that resolve to a
# directory) of the given base directories using a pure-bash glob
glob_subdirs () {
  local -n __out="$1"
  shift
  local base
  shopt -s nullglob
  for base in "$@"; do
    __out+=( "$base"/*/ )
  done
  shopt -u nullglob
}

get_directories () {
  [ -z "$1" ] && [ "$2" = true ] && return
  local directories_file="${1:-"$base_dir/directories"}"
  [ -f "$directories_file" ] || return

  local paths=()
  read_path_list paths "$directories_file"
  [ "${#paths[@]}" -eq 0 ] && return

  # Resolve every path in a single realpath call instead of once per line,
  # normalizing notation so e.g. $HOME/projects and $WIN_HOME/projects don't
  # end up as two differently-styled duplicates of the same base directory
  # (see to_posix_path above) -- also dedupes them so we don't glob the same
  # directory twice.
  local -A seen=()
  local resolved=() dir_path norm
  while IFS="" read -r dir_path; do
    if [ -d "$dir_path" ]; then
      to_posix_path norm "$dir_path"
      if [ -z "${seen[$norm]+x}" ]; then
        seen[$norm]=1
        resolved+=("$norm")
      fi
    fi
  done < <(realpath -- "${paths[@]}" 2>/dev/null)
  [ "${#resolved[@]}" -eq 0 ] && return

  local subdirs=()
  glob_subdirs subdirs "${resolved[@]}"
  [ "${#subdirs[@]}" -eq 0 ] && return

  # Resolve symlinks to their real target in a single realpath call, so two
  # different paths that point at the same location (e.g. a symlink and its
  # target, or two symlinks to the same place) dedupe under `sort -u`.
  local lock
  while IFS="" read -r lock; do
    if [ -d "$lock" ]; then
      to_posix_path norm "${lock%/}"
      printf "%s\n" "$norm"
    fi
    # [ -d "$lock" ] && all_directories+=("${lock%/}")
  done < <(realpath -- "${subdirs[@]}" 2>/dev/null)
}

get_directories_from_path () {
  [ ! -d "$1" ] && return

  local subdirs=()
  glob_subdirs subdirs "$1"
  [ "${#subdirs[@]}" -eq 0 ] && return

  local lock norm
  while IFS="" read -r lock; do
    if [ -d "$lock" ]; then
      to_posix_path norm "${lock%/}"
      printf "%s\n" "$norm"
    fi
    # [ -d "$lock" ] && all_directories+=("${lock%/}")
  done < <(realpath -- "${subdirs[@]}" 2>/dev/null)
}

# Default behavior - Unique list of items from files
if [ "$#" = 0 ]; then
  {
    get_locations &
    get_directories &
  } | sort -u

  # [ -z "$all_directories" ] && exit

  # printf "%s\n" "${all_directories[@]}" | sort -u
  exit 0
fi

show_directories=false
show_locations=false
unique=false
locations_to_get=()
directories_to_get=()
included=()
paths=()

# args parsing
# ref: https://stackoverflow.com/a/14203146
# shellcheck disable=SC2221 disable=SC2222
while [[ $# -gt 0 ]]; do
  case $1 in
    -d|-directories|--directories)
      show_directories=true
      shift # past argument
      ;;
    -l|-locations|--locations)
      show_locations=true
      shift # past argument
      ;;
    -s|-source|--source)
      base_dir="$2"
      shift # past argument
      shift # past value
      ;;
    -f|-filelocations|--file-locations)
      locations_to_get+=("$2")
      shift # past argument
      shift # past value
      ;;
    -b|-filedirectories|--file-directories)
      directories_to_get+=("$2")
      shift # past argument
      shift # past value
      ;;
    -i|-include|--include)
      included+=("$2")
      shift # past argument
      shift # past value
      ;;
    -p|-path|--path)
      paths+=("$2")
      shift # past argument
      shift # past value
      ;;
    -u|-unique|--unique)
      unique=true
      shift # past argument
      ;;
    # Reset array to this point
    +f) locations_to_get=(); shift ;;
    +b) directories_to_get=(); shift ;;
    +i) included=(); shift ;;
    +p) paths=(); shift ;;
    +u) unique=false; shift ;;
    -h|-help|--help|help)
      help
      exit 0
      ;;
    -*|--*)
      echo "unknown option $1"
      exit 1
      ;;
    *)
      echo "unknown option $1"
      exit 1
      ;;
  esac
done

print_projects () {
  if [ "$show_locations" = true ]; then
    get_locations &
  fi

  if [ "$show_directories" = true ]; then
    get_directories &
  fi

  for location in "${locations_to_get[@]}"; do
    get_locations "$location" true &
  done

  for directory in "${directories_to_get[@]}"; do
    get_directories "$directory" true &
  done

  for include in "${included[@]}"; do
    printf "%s\n" "${include%/}" &
    # all_directories+=("${include%/}")
  done

  for path in "${paths[@]}"; do
    get_directories_from_path "$path" &
  done
}

if [ "$unique" = true ]; then
  # printf "%s\n" "${all_directories[@]}" | sort -u
  print_projects | sort -u
else
  # printf "%s\n" "${all_directories[@]}"
  print_projects | cat
fi

